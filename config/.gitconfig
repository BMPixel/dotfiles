[user]
	name = BMPixel
	email = pixelwenbo@gmail.com
[init]
	defaultBranch = main
[credential]
	helper = store
[alias]
	co = checkout
	ci = commit
	st = status
	br = branch
	unstage = reset HEAD --	
	last = log -1 HEAD
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
