[user]
	name = BMPixel
	email = pixelwenbo@gmail.com
[init]
	defaultBranch = main
[credential]
	helper = "!f() { /home/vscode/.vscode-server/bin/97dec172d3256f8ca4bfb2143f3f76b503ca0534/node /tmp/vscode-remote-containers-5659d859f105f66b9a54e96c38c56b277ce6d4fd.js $*; }; f"
[alias]
	co = checkout
	ci = commit
	st = status
	br = branch
	unstage = reset HEAD --	
	last = log -1 HEAD
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
